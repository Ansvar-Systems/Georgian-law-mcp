{
  "id": "ge-doc-1852020",
  "type": "statute",
  "title": "დმანისის მუნიციპალიტეტის გამგეობის და დმანისის მუნიციპალიტეტის საკრებულოს აპარატის საჯარო მოხელეთა დამატებითი საკვალიფიკაციო მოთხოვნების დამტკიცების შესახებ",
  "short_name": "DOC-1852020",
  "status": "in_force",
  "issued_date": "2013-02-22",
  "in_force_date": "2013-02-22",
  "url": "https://www.matsne.gov.ge/ka/document/view/1852020?publication=3",
  "description": "Official consolidated legislation text published by the Legislative Herald of Georgia (matsne.gov.ge).",
  "provisions": [
    {
      "provision_ref": "art1",
      "section": "1",
      "title": "მუხლი 1",
      "content": "დმანისის მუნიციპალიტეტის გამგეობის და დმანისის მუნიციპალიტეტის საკრებულოს აპარატის საჯარო მოხელეთა თანამდებობის დასაკავებლად სავალდებულოა:"
    },
    {
      "provision_ref": "art2",
      "section": "2",
      "title": "მუხლი 2",
      "content": "დადგენილება ამოქმედდეს გამოქვეყნებისთანავე."
    },
    {
      "provision_ref": "art1_dup2",
      "section": "1",
      "title": "მუხლი 1",
      "content": "საქართველოს კონსტიტუცია;"
    },
    {
      "provision_ref": "art2_dup2",
      "section": "2",
      "title": "მუხლი 2",
      "content": "ევროპული ქარტია ადგილობრივი თვითმმართველობის შესახებ."
    },
    {
      "provision_ref": "art3",
      "section": "3",
      "title": "მუხლი 3",
      "content": "„ადგილობრივი თვითმმართველობის შესახებ“ საქართველოს ორგანული კანონი."
    },
    {
      "provision_ref": "art4",
      "section": "4",
      "title": "მუხლი 4",
      "content": "დმანისის მუნიციპალიტეტის საკრებულოს დებულება."
    },
    {
      "provision_ref": "art5",
      "section": "5",
      "title": "მუხლი 5",
      "content": "დმანისის მუნიციპალიტეტის გამგეობის დებულება."
    },
    {
      "provision_ref": "art6",
      "section": "6",
      "title": "მუხლი 6",
      "content": "„საჯარო სამსახურის შესახებ“ საქართველოს კანონი."
    },
    {
      "provision_ref": "art7",
      "section": "7",
      "title": "მუხლი 7",
      "content": "„ნორმატიული აქტების შესახებ“ საქართველოს კანონი."
    },
    {
      "provision_ref": "art8",
      "section": "8",
      "title": "მუხლი 8",
      "content": "საქართველოს ზოგადი ადმინისტრაციული კოდექსი."
    },
    {
      "provision_ref": "art9",
      "section": "9",
      "title": "მუხლი 9",
      "content": "„ადგილობრივი თვითმმართველობის ორგანოების საქმიანობის სახელმწიფო ზედამხედველობის შესახებ“ საქართველოს კანონი."
    },
    {
      "provision_ref": "art10",
      "section": "10",
      "title": "მუხლი 10",
      "content": "საქართველოს კანონი „სახელმწიფო შესყიდვების შესახებ“."
    },
    {
      "provision_ref": "art11",
      "section": "11",
      "title": "მუხლი 11",
      "content": "„სახელმწიფო ბიუჯეტის შესახებ“ საქართველოს კანონი."
    }
  ],
  "definitions": []
}
