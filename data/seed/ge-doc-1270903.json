{
  "id": "ge-doc-1270903",
  "type": "statute",
  "title": "ჯავახეთის დაცული ტერიტორიების შექმნისა და მართვის შესახებ",
  "short_name": "DOC-1270903",
  "status": "in_force",
  "issued_date": "2011-03-22",
  "in_force_date": "2011-03-22",
  "url": "https://www.matsne.gov.ge/ka/document/view/1270903?publication=4",
  "description": "Official consolidated legislation text published by the Legislative Herald of Georgia (matsne.gov.ge).",
  "provisions": [
    {
      "provision_ref": "art1",
      "section": "1",
      "title": "მუხლი 1. კანონის რეგულირების სფერო",
      "content": "1. ეს კანონი არეგულირებს ძირითად სამართლებრივ ურთიერთობებს ჯავახეთის დაცული ტერიტორიების შექმნის, მართვის, დაცვისა და გამოყენების სფეროში.\n2. ჯავახეთის დაცული ტერიტორიებისათვის მიკუთვნებული მიწის, წყლისა და სხვა ბუნებრივი რესურსების განკარგვასთან, დაცვასა და გამოყენებასთან დაკავშირებული ურთიერთობები რეგულირდება ამ კანონითა და საქართველოს სხვა საკანონმდებლო და კანონქვემდებარე ნორმატიული აქტებით."
    },
    {
      "provision_ref": "art2",
      "section": "2",
      "title": "მუხლი 2. კანონის ძირითადი მიზნები და ამოცანები",
      "content": "1. ამ კანონის ძირითადი მიზნებია:\nა) უზრუნველყოს ჯავახეთის დაცული ტერიტორიების შექმნა;\nბ) მოაწესრიგოს ჯავახეთის დაცული ტერიტორიების დაცვისა და გამოყენების სამართლებრივი მექანიზმი.\n2. ამ კანონის ძირითადი ამოცანებია, ჯავახეთის დაცული ტერიტორიების ფარგლებში:\nა) უზრუნველყოს სამხრეთი საქართველოსთვის დამახასიათებელი ბუნებრივი ეკოსისტემებისა და ლანდშაფტების, ბიოტიპებისა და მათი ცალკეული კომპონენტების, ცხოველთა და მცენარეთა სამყაროს დაცვა, აღდგენა და ბიოლოგიური მრავალფეროვნების შენარჩუნება;\nბ) ბუნებრივი პროცესების უწყვეტი განვითარების უზრუნველ ყოფის მიზნით ხელი შეუწყოს ბიოლოგიური მრავალფეროვნებით გამორჩეული ჯავახეთის ზეგნის ჭარბტენიანი, განსაკუთრებით, წყლის ფრინველთა საბინადროდ ვარგისი, ტერიტორიებისა და ჰაბიტატების დაცვასა და აღდგენას;\nგ) უზრუნველყოს მიწის, წყლისა და სხვა ბუნებრივი რესურსების დაცვა, აღდგენა და ამ რესურსებით რაციონალური სარგებლობა; ეკოლოგიური განათლებისა და მეცნიერული კვლევა-ძიებისთვის ხელსაყრელი პირობების შექმნა; ისტორიულ-კულტურული მემკვიდრეობის დაცვა და შენარჩუნება; ვულკანური წარმოშობის ბუნებრივი წყლის ობიექტების (ტბების) ბუნებრივი ბიოეკოლოგიური რეჟიმის დაცვა და მათზე მონიტორინგის განხორციელება;\nდ) ხელი შეუწყოს ბუნებრივ და ადამიანის მიერ სახეცვლილ გარემოში რეკრეაციის, ტურიზმისა და სოფლის მეურნეობის მდგრადი განვითარებისთვის ხელსაყრელი პირობების შექმნას."
    },
    {
      "provision_ref": "art3",
      "section": "3",
      "title": "მუხლი 3. ჯავახეთის დაცული ტერიტორიების კატეგორიები",
      "content": "ჯავახეთის დაცული ტერიტორიები საქართველოს დაცული ტერიტორიების სისტემის ნაწილია. ჯავახეთის დაცული ტერიტორიები იქმნება ამ კანონით დადგენილი საზღვრების ფარგლებში და იყოფა შემდეგ კატეგორიებად:\nა) ჯავახეთის ეროვნული პარკი;\nბ) კარწახის ჭაობის აღკვეთილი;\nბ^1) ფარავნის ტბის აღკვეთილი;\nბ^2) საღამოს ტბის აღკვეთილი;\nბ^3) აბულის ტბის აღკვეთილი;\nგ) სულდის ჭაობის აღკვეთილი;\nდ) ხანჩალის ტბის აღკვეთილი;\nე) ბუღდაშენის ტბის აღკვეთილი;\nვ) მადათაფის ტბის აღკვეთილი;\nზ) ჯავახეთის მრავალმხრივი გამოყენების ტერიტორია (დამხმარე ზონა)."
    },
    {
      "provision_ref": "art4",
      "section": "4",
      "title": "მუხლი 4. ჯავახეთის ეროვნული პარკის მდებარეობა, ფართობი და საზღვრები",
      "content": "1. ჯავახეთის ეროვნული პარკი იქმნება ახალქალაქისა და ნინოწმინდის მუნიციპალიტეტების ადმინისტრაციული საზღვრების ფარგლებში მოქცეულ ტერიტორიაზე, რომლის საერთო ფართობი შეადგენს 13498,02 ჰექტარს.\n2. ჯავახეთის ეროვნული პარკი მოიცავს შემდეგ გეოგრაფიულ კოორდინატებს:\nა)\n№\nX\nY\n№\nX\nY\n№\nX\nY\n№\nX\nY\n1\n372973\n4560972\n32\n369116\n4566387\n63\n353651\n4566290\n94\n365496\n4565144\n2\n372864\n4559800\n33\n369016\n4567102\n64\n364844\n4568797\n95\n365738\n4565078\n3\n373106\n4558565\n34\n369199\n4567646\n65\n358775\n4565127\n96\n365585\n4564802\n4\n373162\n4557360\n35\n368385\n4567790\n66\n374284\n4555978\n97\n365457\n4564828\n5\n374187\n4556270\n36\n367792\n4567959\n67\n374128\n4556098\n98\n363148\n4567970\n6\n374480\n4556070\n37\n367075\n4568770\n68\n374295\n4556197\n99\n363266\n4567968\n7\n375060\n4555856\n38\n366654\n4568522\n69\n357716\n4563604\n100\n363311\n4567759\n8\n375447\n4555431\n39\n365826\n4568250\n70\n357870\n4563509\n101\n363273\n4567700\n9\n375559\n4555189\n40\n365443\n4568591\n71\n357914\n4563482\n102\n363212\n4567684\n10\n375304\n4554899\n41\n364360\n4568765\n72\n357548\n4562876\n103\n363176\n4567700\n11\n375900\n4555149\n42\n363828\n4568685\n73\n357317\n4562996\n104\n363128\n4567920\n12\n376437\n4555374\n43\n363294\n4568605\n74\n357360\n4563076\n105\n357693\n4563619\n13\n374416\n4565283\n44\n363227\n4568391\n75\n357363\n4563167\n106\n350467\n4566371\n14\n373189\n4563993\n45\n362946\n4568551\n76\n357312\n4563158\n107\n349315\n4566253\n15\n373019\n4564560\n46\n362360\n4568370\n77\n357303\n4563169\n108\n353531\n4566406\n16\n372337\n4564074\n47\n362120\n4567767\n78\n357518\n4563337\n109\n353199\n4566477\n17\n372053\n4563367\n48\n361832\n4567041\n79\n357399\n4562953\n110\n351381\n4566564\n18\n371526\n4562777\n49\n361783\n4566648\n80\n357412\n4562946\n111\n352829\n4566522\n19\n371190\n4562842\n50\n361065\n4566191\n81\n357227\n4562460\n112\n374569\n4563728\n20\n370883\n4561985\n51\n360235\n4566432\n82\n357210\n4562260\n113\n373678\n4562924