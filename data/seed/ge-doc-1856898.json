  "description": "Official consolidated legislation text published by the Legislative Herald of Georgia (matsne.gov.ge).",
  "provisions": [
    {
      "provision_ref": "art1",
      "section": "1",
      "title": "მუხლი 1",
      "content": "დამტკიცდეს სიღნაღის მუნიციპალიტეტის ადგილობრივი თვითმმართველობის საჯარო მოსამსახურეთა კონკურსისა და ატესტაციის ჩატარების წესი და საკონურსო-საატესტაციო კომისიის დებულება (დანართი №1), მოხელის დახასიათება (დანართი №2) და საატესტაციო ფურცელი (დანართი №3)."
    },
    {
      "provision_ref": "art2",
      "section": "2",
      "title": "მუხლი 2",
      "content": "დადგენილება ამოქმედდეს გამოქვეყნებისთანავე."
    },
    {
      "provision_ref": "art1_dup2",
      "section": "1",
      "title": "მუხლი 1",
      "content": "საკონკურსო-საატესტაციო კომისია"
    },
    {
      "provision_ref": "art2_dup2",
      "section": "2",
      "title": "მუხლი 2",
      "content": "კომისიის შემადგენლობა"
    },
    {
      "provision_ref": "art3",
      "section": "3",
      "title": "მუხლი 3",
      "content": "კომისიის აპარატი (სამდივნო)"
    },
    {
      "provision_ref": "art4",
      "section": "4",
      "title": "მუხლი 4",
      "content": "საპრეტენზიო კომისია"
