{
  "id": "ge-doc-77062",
  "type": "statute",
  "title": ",,საქართველოს პარლამენტის 2008 წლის 21 მაისის არჩევნებზე საოლქო საარჩევნო კომისიებისათვის საჭირო ფულადი სახსრების განაწილებისა და გამოყენების წესისა და ზოგიერთი საარჩევნო ღონისძიების განსაზღვრის თაობაზე“",
  "short_name": "DOC-77062",
  "status": "in_force",
  "issued_date": "2008-03-31",
  "in_force_date": "2008-03-31",
  "url": "https://www.matsne.gov.ge/ka/document/view/77062?publication=1",
  "description": "Official consolidated legislation text published by the Legislative Herald of Georgia (matsne.gov.ge).",
  "provisions": [
    {
      "provision_ref": "art1",
      "section": "1",
      "title": "მუხლი 1",
      "content": "დამტკიცდეს საოლქო საარჩევნო კომისიებისათვის საჭირო ფულადი სახსრების განაწილებისა და გამოყენების წესი (ხარჯთაღრიცხვა) დანართის შესაბამისად."
    },
    {
      "provision_ref": "art2",
      "section": "2",
      "title": "მუხლი 2",
      "content": "ცესკოს მიერ საოლქო საარჩევნო კომისიებისათვის გამოყოფილი თანხები ჩაირიცხება საქართველოს ორგანული კანონის „საქართველოს საარჩევნო კოდექსი“ 34-ე მუხლის პირველი პრიმა პუნქტის თანახმად გახსნილ ანგარიშებზე ბანკებში."
    },
    {
      "provision_ref": "art3",
      "section": "3",
      "title": "მუხლი 3",
      "content": "საქართველოს ცენტრალურმა საარჩევნო კომისიამ საარჩევნო ოლქებისათვის გამოყოფილი თანხების ჩარიცხვა მათ მიმდინარე ანგარიშებზე უზრუნველყოს კენჭისყრამდე არა უგვიანეს 45 დღისა."
    },
    {
      "provision_ref": "art4",
      "section": "4",
      "title": "მუხლი 4",
      "content": "ეს დადგენილება შეიძლება გასაჩივრდეს თბილისის საქალაქო სასამართლოში (მისამართი: ქ. თბილისი, სარაჯიშვილის ქ. №1 ა ) მისი მიღებიდან 1 კალენდარული დღის ვადაში."
    },
    {
      "provision_ref": "art5",
